generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(uuid())
  name      String
  cpf       String  @unique @db.VarChar(11)
  phone     String  @db.VarChar(15)
  email     String  @unique
  active    Boolean @default(true)
  password  String
  resetCode String?
  role      Roles   @default(admin)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  master       Master?
  admin        Admin?
  doctor       Doctor?
  patient      Patient?
  auditLogs    AuditLog[]
  triagens     Triagem[]
  patientFiles PatientFile[]

  @@map("users")
}

model Master {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("masters")
}

model Admin {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  utiAccess Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Doctor {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  crm                String       @unique @db.VarChar(20)
  specialty          String
  monthlySlots       Int          @default(0)
  weeklyAvailability Json?
  status             DoctorStatus @default(active)
  utiAccess          Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments  Appointment[]
  prescriptions Prescription[]
  anamises      Anaminese[]
  requests      Request[]

  @@index([specialty])
  @@map("doctors")
}

model Patient {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  age         Int
  birthDate   DateTime?
  gender      Genders
  address     Json?
  motherName  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments  Appointment[]
  prescriptions Prescription[]
  requests      Request[]
  anamises      Anaminese[]
  uti           Uti?
  triagens      Triagem[]
  files         PatientFile[]

  @@map("patients")
}

model Uti {
  id        String   @id @default(uuid())
  patientId String?  @unique
  patient   Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  status   StatusUti @default(available)
  roomLink String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("utis")
}

model Triagem {
  id            String       @id @default(uuid())
  patientId     String
  patient       Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  // Sinais Vitais
  frequenciaCardiaca      Float?
  frequenciaCardiacaUnit  String? // BPM
  frequenciaCardiacaInstr String? // OXIMETRO DE PULSO, etc

  frequenciaRespiratoria      Float?
  frequenciaRespiratoriaUnit  String? // RPM
  frequenciaRespiratoriaInstr String? // VISUAL (VISAO), etc

  spo2      Float?
  spo2Unit  String? // %
  spo2Instr String? // OXIMETRO DE PULSO

  temperatura      Float?
  temperaturaUnit  String? // °C
  temperaturaInstr String? // TERMOMETRO

  pressaoArterialSistolica  Float?
  pressaoArterialDiastolica Float?
  pressaoArterialUnit       String? // MMHG
  pressaoArterialInstr      String? // ESFIGMOMANOMETRO

  pam Float? // P.A.M.: -

  glicemia      Float?
  glicemiaUnit  String? // MG/DL
  glicemiaInstr String? // GLICOSIMENTRO

  pressaoVenosaCentral      Float?
  pressaoVenosaCentralUnit  String?
  pressaoVenosaCentralInstr String?

  pressaoIntracraniana      Float?
  pressaoIntracranianaUnit  String? // MMHG
  pressaoIntracranianaInstr String? // MONITOR

  // Medidas
  capnografia      Float?
  capnografiaUnit  String? // MMHG
  capnografiaInstr String? // CAPNOGRAFO

  peso      Float?
  pesoUnit  String? // KG
  pesoInstr String? // BALANCA

  altura      Float?
  alturaUnit  String? // CM
  alturaInstr String? // REGUA OU TRENA

  perimetroCefalico      Float?
  perimetroCefalicoUnit  String? // CM
  perimetroCefalicoInstr String? // FITA METRICA

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
  @@index([appointmentId])
  @@map("triagens")
}

// Junction Models

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  doctorId        String
  appointmentDate DateTime          @db.Timestamptz(6)
  reason          String?
  status          AppointmentStatus @default(scheduled)
  notes           String?
  roomName        String?
  roomLink        String?
  durationMinutes Int?
  feedbackPatient String?
  feedbackDoctor  String?
  finishedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  doctor          Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptions   Prescription[]
  triagens        Triagem[]
  requests        Request[]

  @@unique([patientId, doctorId, appointmentDate])
  @@index([doctorId])
  @@index([patientId])
  @@map("appointments")
}

model Prescription {
  id                 String              @id @default(uuid())
  patientId          String
  doctorId           String
  appointmentId      String?
  orientacoesGerais  String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  appointment        Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctor             Doctor              @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient            Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicamentos       Medicamento[]

  @@index([doctorId])
  @@index([patientId])
  @@map("prescriptions")
}

model Medicamento {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  
  nome          String
  dosagem       String
  frequencia    String
  duracao       String
  via           String
  orientacoes   String?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([prescriptionId])
  @@map("medicamentos")
}

model Request {
  id String @id @default(uuid())

  type    RequestType
  status  RequestStatus @default(pending)
  details Json?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  patient       Patient?     @relation(fields: [patientId], references: [id])
  patientId     String?
  doctor        Doctor?      @relation(fields: [doctorId], references: [id])
  doctorId      String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  appointmentId String?

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([status])
  @@map("requests")
}

model Anaminese {
  id        String @id @default(uuid())
  patientId String
  doctorId  String
  content   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patient   Patient  @relation(fields: [patientId], references: [id])
  doctor    Doctor   @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@map("anamneses")
}

model AuditLog {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action      String
  description String
  content     Json?
  impactLevel ImpactLevel @default(low)
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime    @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([impactLevel])
  @@index([timestamp])
  @@map("audit_logs")
}

model PatientFile {
  id        String   @id @default(uuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Metadados
  fileName String
  fileType String
  mimeType String
  fileSize Int // bytes

  // Storage
  storageKey String  @unique // chave no S3/R2
  storageUrl String? // URL pública (se aplicável)

  // Segurança
  uploadedBy     String
  uploadedByUser User   @relation(fields: [uploadedBy], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete

  @@index([patientId])
  @@index([fileType])
  @@map("patient_files")
}

// Enums

enum Roles {
  master // usuário mestre
  admin // administrador
  doctor // médico
  patient // paciente
}

enum Genders {
  male // masculino
  female // feminino
  indefinido // indefinido
  ignorado // ignorado
}

enum StatusUti {
  available // UTI disponível
  occupied
}

enum DoctorStatus {
  active // Médico ativo
  inactive // Médico inativo
  onLeave // Médico em licença temporária
}

enum AppointmentStatus {
  scheduled // Consulta agendada
  inProgress // Consulta em andamento
  completed // Consulta concluída
  cancelled // Consulta cancelada
  noShow // Paciente não compareceu à consulta agendada
}

enum RequestType {
  appointment // Solicitação de consulta
  prescription // Solicitação de prescrição
  consultation // Solicitação de consulta médica
  utiAdmission // Solicitação de internação em UTI
  other // Outros tipos de solicitação
}

enum RequestStatus {
  pending // Solicitação pendente
  approved // Solicitação aprovada
  rejected // Solicitação rejeitada
  completed // Solicitação concluída
  cancelled // Solicitação cancelada
}

enum ImpactLevel {
  low // Baixo impacto - visualização de dados
  medium // Médio impacto - criação/atualização de dados
  high // Alto impacto - exclusão ou alteração de dados sensíveis
  critical // Crítico - alterações de segurança ou configurações do sistema
}

enum FileCategory {
  EXAM_RESULT // Resultado de exames
  MEDICAL_IMAGE // Imagens médicas (RX, tomografia)
  PRESCRIPTION // Receitas médicas
  DOCUMENT // Documentos gerais
  REPORT // Laudos
  CONSENT_FORM // Termos de consentimento
}
