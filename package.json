{
	"name": "medvision-backend",
	"version": "1.0.0",
	"description": "",
	"main": "src/server.ts",
	"scripts": {
		"dev": "tsx watch --env-file=.env src/server.ts",
		"build": "tsc",
		"start": "node --require ./scripts/register-dist-paths.cjs dist/server.js",
		"test": "tsx --test \"tests/**/*.test.ts\"",
		"format": "biome format --write",
		"db:generate": "pnpm exec prisma generate",
		"db:migrate": "pnpm exec prisma migrate deploy",
		"db:migrate:dev": "pnpm exec prisma migrate dev",
		"db:push": "pnpm exec prisma db push",
		"db:studio": "pnpm exec prisma studio",
		"db:reset": "pnpm exec prisma migrate reset --force",
		"db:seed:admin": "tsx scripts/seed-admin.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.20.0",
	"pnpm": {
		"overrides": {
			"fast-jwt": "6.2.4",
			"follow-redirects": "1.16.0",
			"effect": "3.20.0",
			"defu": "6.1.5",
			"ajv": "8.18.0",
			"yaml": "2.8.3",
			"bn.js": "4.12.3",
			"uuid": "14.0.0"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.4",
		"@types/bcrypt": "^6.0.0",
		"@types/node": "^24.10.0",
		"@types/node-cron": "^3.0.11",
		"@types/pdfkit": "^0.17.4",
		"@types/pg": "^8.15.6",
		"prisma": "^6.19.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1038.0",
		"@aws-sdk/s3-request-presigner": "^3.1038.0",
		"@daily-co/daily-js": "^0.85.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.1.0",
		"@fastify/jwt": "^10.0.0",
		"@fastify/multipart": "^9.3.0",
		"@fastify/swagger": "^9.6.0",
		"@fastify/websocket": "^11.2.0",
		"@prisma/adapter-pg": "^6.19.0",
		"@prisma/client": "^6.19.0",
		"@prisma/internals": "^6.19.0",
		"@scalar/fastify-api-reference": "^1.39.3",
		"axios": "^1.15.2",
		"bcrypt": "^6.0.0",
		"dotenv": "^17.2.3",
		"fastify": "^5.8.5",
		"fastify-plugin": "^5.1.0",
		"fastify-type-provider-zod": "^6.1.0",
		"node-cron": "^4.2.1",
		"pdfkit": "^0.17.2",
		"pg": "^8.16.3",
		"postgres": "^3.4.7",
		"resend": "^6.12.2",
		"tsx": "^4.20.6",
		"zod": "^4.1.12"
	}
}
