# Database
DATABASE_URL=postgresql://medvision:change-me@postgres:5432/medvision
POSTGRES_USER=medvision
POSTGRES_PASSWORD=change-me
POSTGRES_DB=medvision
DB_PORT=5432

# Server
API_VERSION=1
PORT=3333
NODE_ENV=development
API_DOMAIN=api.example.com
APP_URL=http://localhost:3333
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Security secrets
JWT_SECRET=change-me-long-random-jwt-secret
COOKIE_SECRET=change-me-long-random-cookie-secret
SIGNATURE_SECRET_KEY=change-me-long-random-signature-secret

# Admin seed
ADMIN_NAME=Administrador MedVision
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Daily.co
DAILY_CO_API_KEY=change-me-daily-api-key
DAILY_DOMAIN=your-domain.daily.co

# Email
RESEND_API_KEY=re_change_me
EMAIL_FROM=MedVision <noreply@example.com>

# Notification providers
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
SMS_API_URL=
SMS_API_TOKEN=

# Cloudflare R2 Storage
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=change-me-r2-access-key-id
R2_SECRET_ACCESS_KEY=change-me-r2-secret-access-key
R2_BUCKET_NAME=medvision-files
